DATABASE_URL=./margin-runner.db

# eBay Browse API — free at https://developer.ebay.com/my/keys (Production keyset)
# App ID → EBAY_CLIENT_ID, Cert ID → EBAY_CLIENT_SECRET
# Used for market price lookup on lots missing a retail value.
EBAY_CLIENT_ID=your_ebay_app_id
EBAY_CLIENT_SECRET=your_ebay_cert_id
EBAY_REDIRECT_URI=http://localhost:3000

AMAZON_ACCESS_KEY_ID=your_amazon_access_key
AMAZON_SECRET_ACCESS_KEY=your_amazon_secret_key
AMAZON_SELLER_ID=your_seller_id
AMAZON_REGION=US

# LLM Provider: "claude" (default) or "ollama"
LLM_PROVIDER=claude
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-opus-4-7

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://rig1.clsystems.nl:11434
OLLAMA_MODEL=llama3.2

KEEPA_API_KEY=your_keepa_api_key

TARGET_WEEKLY_REVENUE=2000
MIN_MARGIN_PERCENT=20
